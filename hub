local function GetClosestPlayer(maxDistance, hitPart)
    local closest = nil
    local closestDist = maxDistance or math.huge
    local myChar = LocalPlayer.Character
    if not myChar then return nil end
    local myHrp = myChar:FindFirstChild("HumanoidRootPart")
    if not myHrp then return nil end

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local hrp = plr.Character:FindFirstChild(hitPart or "HumanoidRootPart")
            if hrp then
                local dist = (hrp.Position - myHrp.Position).Magnitude
                if dist < closestDist then
                    closestDist = dist
                    closest = plr
                end
            end
        end
    end
    return closest
end

local function IsPlayerValidTarget(plr)
    if not plr or not plr.Character then return false end
    if plr == LocalPlayer then return false end

    if State.Whitelist.Enabled then
        local isWhitelisted = false
        for _, name in ipairs(State.Whitelist.Players) do
            if plr.Name == name then
                isWhitelisted = true
                break
            end
        end
        if State.Whitelist.FriendsOnly and not plr:IsFriendsWith(LocalPlayer.UserId) then
            return false
        end
        if not isWhitelisted and #State.Whitelist.Players > 0 then
            return false
        end
    end

    if State.Checks.Visible then
        local myChar = LocalPlayer.Character
        if myChar then
            local myHrp = myChar:FindFirstChild("HumanoidRootPart")
            local targetHrp = plr.Character:FindFirstChild("HumanoidRootPart")
            if myHrp and targetHrp then
                local ray = Ray.new(myHrp.Position, (targetHrp.Position - myHrp.Position).Unit * (targetHrp.Position - myHrp.Position).Magnitude)
                local hit = workspace:FindPartOnRayWithIgnoreList(ray, {myChar, plr.Character})
                if hit then return false end
            end
        end
    end

    return true
end

