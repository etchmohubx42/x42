        local shouldTrigger = false
        if State.TriggerBot.ActivationMode == "Always" then
            shouldTrigger = true
        elseif State.TriggerBot.ActivationMode == "Hold" and TriggerBotActive then
            shouldTrigger = true
        elseif State.TriggerBot.ActivationMode == "Toggle" and TriggerBotActive then
